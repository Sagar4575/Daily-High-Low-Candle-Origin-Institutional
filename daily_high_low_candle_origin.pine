//@version=5
indicator("Daily High Low – Candle Origin (Institutional)", overlay=true)

// ─────────────────────────────
// SAFETY (MANDATORY)
// ─────────────────────────────
if timeframe.isdaily
    runtime.error("This indicator works only on intraday timeframes.")

// ─────────────────────────────
// SETTINGS
// ─────────────────────────────
showCurrentHigh = input.bool(true, "Show Current Daily High")
showCurrentLow  = input.bool(true, "Show Current Daily Low")
showPrevHigh    = input.bool(true, "Show Previous Daily High")
showPrevLow     = input.bool(true, "Show Previous Daily Low")

rightExtendBars = input.int(50, "Right Extension (bars)", minval=10)

// ─────────────────────────────
// LINE CUSTOMIZATION
// ─────────────────────────────
currHighColor  = input.color(color.gray,                  "Current High – Color",    group="Line Style")
currHighStyle  = input.string("dashed", "Current High – Style",  options=["solid","dashed","dotted"], group="Line Style")
currHighWidth  = input.int(1, "Current High – Width", minval=1, maxval=4, group="Line Style")

currLowColor   = input.color(color.gray,                  "Current Low  – Color",    group="Line Style")
currLowStyle   = input.string("dashed", "Current Low  – Style",  options=["solid","dashed","dotted"], group="Line Style")
currLowWidth   = input.int(1, "Current Low  – Width", minval=1, maxval=4, group="Line Style")

prevHighColor  = input.color(color.new(color.gray, 60),   "Prev High    – Color",    group="Line Style")
prevHighStyle  = input.string("dashed", "Prev High    – Style",  options=["solid","dashed","dotted"], group="Line Style")
prevHighWidth  = input.int(1, "Prev High    – Width", minval=1, maxval=4, group="Line Style")

prevLowColor   = input.color(color.new(color.gray, 60),   "Prev Low     – Color",    group="Line Style")
prevLowStyle   = input.string("dashed", "Prev Low     – Style",  options=["solid","dashed","dotted"], group="Line Style")
prevLowWidth   = input.int(1, "Prev Low     – Width", minval=1, maxval=4, group="Line Style")

// Helper: convert string → line.style_*
f_style(s) =>
    s == "solid"  ? line.style_solid  :
     s == "dotted" ? line.style_dotted :
     line.style_dashed

// ─────────────────────────────
// DAILY CHANGE (EXCHANGE BASED)
// ─────────────────────────────
isNewDay = timeframe.change("D")
rightX   = bar_index + rightExtendBars

// ─────────────────────────────
// CURRENT DAILY HIGH / LOW
// ─────────────────────────────
var float currHigh = na
var float currLow  = na
var int   currHighBar = na
var int   currLowBar  = na

if isNewDay
    currHigh := high
    currLow  := low
    currHighBar := bar_index
    currLowBar  := bar_index
else
    if high > currHigh
        currHigh := high
        currHighBar := bar_index
    if low < currLow
        currLow := low
        currLowBar := bar_index

// ─────────────────────────────
// PREVIOUS DAILY VALUES (LOCKED)
// ─────────────────────────────
var float prevHigh = na
var float prevLow  = na
var int   prevHighBar = na
var int   prevLowBar  = na

if isNewDay and not na(currHigh[1])
    prevHigh := currHigh[1]
    prevLow  := currLow[1]
    prevHighBar := currHighBar[1]
    prevLowBar  := currLowBar[1]

// ─────────────────────────────
// CURRENT DAY LINES (UPDATING)
// ─────────────────────────────
var line currHighLine = na
var line currLowLine  = na

if showCurrentHigh and not na(currHigh)
    if na(currHighLine)
        currHighLine := line.new(currHighBar, currHigh, rightX, currHigh, color=currHighColor, style=f_style(currHighStyle), width=currHighWidth)
    else
        line.set_xy1(currHighLine, currHighBar, currHigh)
        line.set_xy2(currHighLine, rightX, currHigh)
        line.set_color(currHighLine, currHighColor)
        line.set_style(currHighLine, f_style(currHighStyle))
        line.set_width(currHighLine, currHighWidth)

if showCurrentLow and not na(currLow)
    if na(currLowLine)
        currLowLine := line.new(currLowBar, currLow, rightX, currLow, color=currLowColor, style=f_style(currLowStyle), width=currLowWidth)
    else
        line.set_xy1(currLowLine, currLowBar, currLow)
        line.set_xy2(currLowLine, rightX, currLow)
        line.set_color(currLowLine, currLowColor)
        line.set_style(currLowLine, f_style(currLowStyle))
        line.set_width(currLowLine, currLowWidth)

// ─────────────────────────────
// PREVIOUS DAY LINES (FIXED PRICE)
// ─────────────────────────────
var line prevHighLine = na
var line prevLowLine  = na

if isNewDay and not na(prevHigh)
    line.delete(prevHighLine)
    line.delete(prevLowLine)

    if showPrevHigh
        prevHighLine := line.new(prevHighBar, prevHigh, rightX, prevHigh, color=prevHighColor, style=f_style(prevHighStyle), width=prevHighWidth)

    if showPrevLow
        prevLowLine := line.new(prevLowBar, prevLow, rightX, prevLow, color=prevLowColor, style=f_style(prevLowStyle), width=prevLowWidth)

// Keep right edge aligned
if not isNewDay
    if showPrevHigh and not na(prevHighLine)
        line.set_xy2(prevHighLine, rightX, prevHigh)
        line.set_color(prevHighLine, prevHighColor)
        line.set_style(prevHighLine, f_style(prevHighStyle))
        line.set_width(prevHighLine, prevHighWidth)
    if showPrevLow and not na(prevLowLine)
        line.set_xy2(prevLowLine, rightX, prevLow)
        line.set_color(prevLowLine, prevLowColor)
        line.set_style(prevLowLine, f_style(prevLowStyle))
        line.set_width(prevLowLine, prevLowWidth)

// ─────────────────────────────
// LABELS (TEXT ONLY MOVES)
// ─────────────────────────────
var label currHighLabel = na
var label currLowLabel  = na
var label prevHighLabel = na
var label prevLowLabel  = na

// Current labels
if showCurrentHigh and not na(currHigh)
    if na(currHighLabel)
        currHighLabel := label.new(bar_index + 5, currHigh, "Current Daily High", style=label.style_none, textcolor=color.gray, size=size.small)
    else
        label.set_xy(currHighLabel, bar_index + 5, currHigh)

if showCurrentLow and not na(currLow)
    if na(currLowLabel)
        currLowLabel := label.new(bar_index + 5, currLow, "Current Daily Low", style=label.style_none, textcolor=color.gray, size=size.small)
    else
        label.set_xy(currLowLabel, bar_index + 5, currLow)

// Previous labels
if showPrevHigh and not na(prevHigh)
    if isNewDay
        label.delete(prevHighLabel)
        prevHighLabel := label.new(bar_index + 5, prevHigh, "Previous Daily High", style=label.style_none, textcolor=color.new(color.gray, 60), size=size.small)
    else
        label.set_xy(prevHighLabel, bar_index + 5, prevHigh)

if showPrevLow and not na(prevLow)
    if isNewDay
        label.delete(prevLowLabel)
        prevLowLabel := label.new(bar_index + 5, prevLow, "Previous Daily Low", style=label.style_none, textcolor=color.new(color.gray, 60), size=size.small)
    else
        label.set_xy(prevLowLabel, bar_index + 5, prevLow)
