//@version=5
indicator("Daily High Low – Candle Origin (Institutional)", overlay=true)

// ─────────────────────────────
// SAFETY (MANDATORY)
// ─────────────────────────────
if timeframe.isdaily
    runtime.error("This indicator works only on intraday timeframes.")

// ─────────────────────────────
// GENERAL SETTINGS
// ─────────────────���───────────
showCurrentHigh = input.bool(true,  "Show Current Daily High")
showCurrentLow  = input.bool(true,  "Show Current Daily Low")
showPrevHigh    = input.bool(true,  "Show Previous Daily High")
showPrevLow     = input.bool(true,  "Show Previous Daily Low")
rightExtendBars = input.int(50,     "Right Extension (bars)", minval=10)

// ─────────────────────────────
// CURRENT HIGH – GROUP
// ─────────────────────────────
currHighColor      = input.color(color.gray,   "Line Color",         group="Current High")
currHighStyle      = input.string("dashed",    "Line Style",         group="Current High", options=["solid","dashed","dotted"])
currHighWidth      = input.int(1,              "Line Width",         group="Current High", minval=1, maxval=4)
showCurrHighLabel  = input.bool(true,          "Show Label",         group="Current High")
currHighLabelText  = input.string("Current Daily High", "Label Text", group="Current High")
currHighLabelColor = input.color(color.gray,   "Label Color",        group="Current High")
currHighLabelSize  = input.string("small",     "Label Size",         group="Current High", options=["tiny","small","normal","large"])

// ─────────────────────────────
// CURRENT LOW – GROUP
// ─────────────────────────────
currLowColor       = input.color(color.gray,   "Line Color",         group="Current Low")
currLowStyle       = input.string("dashed",    "Line Style",         group="Current Low",  options=["solid","dashed","dotted"])
currLowWidth       = input.int(1,              "Line Width",         group="Current Low",  minval=1, maxval=4)
showCurrLowLabel   = input.bool(true,          "Show Label",         group="Current Low")
currLowLabelText   = input.string("Current Daily Low", "Label Text", group="Current Low")
currLowLabelColor  = input.color(color.gray,   "Label Color",        group="Current Low")
currLowLabelSize   = input.string("small",     "Label Size",         group="Current Low",  options=["tiny","small","normal","large"])

// ─────────────────────────────
// PREVIOUS HIGH – GROUP
// ─────────────────────────────
prevHighColor      = input.color(color.new(color.gray, 60), "Line Color",  group="Previous High")
prevHighStyle      = input.string("dashed",    "Line Style",         group="Previous High", options=["solid","dashed","dotted"])
prevHighWidth      = input.int(1,              "Line Width",         group="Previous High", minval=1, maxval=4)
showPrevHighLabel  = input.bool(true,          "Show Label",         group="Previous High")
prevHighLabelText  = input.string("Previous Daily High", "Label Text", group="Previous High")
prevHighLabelColor = input.color(color.new(color.gray, 60), "Label Color", group="Previous High")
prevHighLabelSize  = input.string("small",     "Label Size",         group="Previous High", options=["tiny","small","normal","large"])

// ─────────────────────────────
// PREVIOUS LOW – GROUP
// ─────────────────────────────
prevLowColor       = input.color(color.new(color.gray, 60), "Line Color",  group="Previous Low")
prevLowStyle       = input.string("dashed",    "Line Style",         group="Previous Low",  options=["solid","dashed","dotted"])
prevLowWidth       = input.int(1,              "Line Width",         group="Previous Low",  minval=1, maxval=4)
showPrevLowLabel   = input.bool(true,          "Show Label",         group="Previous Low")
prevLowLabelText   = input.string("Previous Daily Low", "Label Text", group="Previous Low")
prevLowLabelColor  = input.color(color.new(color.gray, 60), "Label Color", group="Previous Low")
prevLowLabelSize   = input.string("small",     "Label Size",         group="Previous Low",  options=["tiny","small","normal","large"])

// ─────────────────────────────
// HELPERS
// ─────────────────────────────
f_style(s) =>
    s == "solid"  ? line.style_solid  :
     s == "dotted" ? line.style_dotted :
     line.style_dashed

f_size(s) =>
    s == "tiny"   ? size.tiny   :
     s == "normal" ? size.normal :
     s == "large"  ? size.large  :
     size.small

// ─────────────────────────────
// DAILY CHANGE (EXCHANGE BASED)
// ─────────────────────────────
isNewDay = timeframe.change("D")
rightX   = bar_index + rightExtendBars

// ─────────────────────────────
// CURRENT DAILY HIGH / LOW
// ─────────────────────────────
var float currHigh    = na
var float currLow     = na
var int   currHighBar = na
var int   currLowBar  = na

if isNewDay
    currHigh    := high
    currLow     := low
    currHighBar := bar_index
    currLowBar  := bar_index
else
    if high > currHigh
        currHigh    := high
        currHighBar := bar_index
    if low < currLow
        currLow    := low
        currLowBar := bar_index

// ─────────────────────────────
// PREVIOUS DAILY VALUES (LOCKED)
// ─────────────────────────────
var float prevHigh    = na
var float prevLow     = na
var int   prevHighBar = na
var int   prevLowBar  = na

if isNewDay and not na(currHigh[1])
    prevHigh    := currHigh[1]
    prevLow     := currLow[1]
    prevHighBar := currHighBar[1]
    prevLowBar  := currLowBar[1]

// ─────────────────────────────
// CURRENT DAY LINES (UPDATING)
// ─────────────────────────────
var line currHighLine = na
var line currLowLine  = na

if showCurrentHigh and not na(currHigh)
    if na(currHighLine)
        currHighLine := line.new(currHighBar, currHigh, rightX, currHigh, color=currHighColor, style=f_style(currHighStyle), width=currHighWidth)
    else
        line.set_xy1(currHighLine, currHighBar, currHigh)
        line.set_xy2(currHighLine, rightX, currHigh)
        line.set_color(currHighLine, currHighColor)
        line.set_style(currHighLine, f_style(currHighStyle))
        line.set_width(currHighLine, currHighWidth)

if showCurrentLow and not na(currLow)
    if na(currLowLine)
        currLowLine := line.new(currLowBar, currLow, rightX, currLow, color=currLowColor, style=f_style(currLowStyle), width=currLowWidth)
    else
        line.set_xy1(currLowLine, currLowBar, currLow)
        line.set_xy2(currLowLine, rightX, currLow)
        line.set_color(currLowLine, currLowColor)
        line.set_style(currLowLine, f_style(currLowStyle))
        line.set_width(currLowLine, currLowWidth)

// ─────────────────────────────
// PREVIOUS DAY LINES (FIXED PRICE)
// ─────────────────────────────
var line prevHighLine = na
var line prevLowLine  = na

if isNewDay and not na(prevHigh)
    line.delete(prevHighLine)
    line.delete(prevLowLine)

    if showPrevHigh
        prevHighLine := line.new(prevHighBar, prevHigh, rightX, prevHigh, color=prevHighColor, style=f_style(prevHighStyle), width=prevHighWidth)

    if showPrevLow
        prevLowLine := line.new(prevLowBar, prevLow, rightX, prevLow, color=prevLowColor, style=f_style(prevLowStyle), width=prevLowWidth)

if not isNewDay
    if showPrevHigh and not na(prevHighLine)
        line.set_xy2(prevHighLine, rightX, prevHigh)
        line.set_color(prevHighLine, prevHighColor)
        line.set_style(prevHighLine, f_style(prevHighStyle))
        line.set_width(prevHighLine, prevHighWidth)
    if showPrevLow and not na(prevLowLine)
        line.set_xy2(prevLowLine, rightX, prevLow)
        line.set_color(prevLowLine, prevLowColor)
        line.set_style(prevLowLine, f_style(prevLowStyle))
        line.set_width(prevLowLine, prevLowWidth)

// ─────────────────────────────
// LABELS (FULLY CUSTOMIZABLE)
// ─────────────────────────────
var label currHighLabel = na
var label currLowLabel  = na
var label prevHighLabel = na
var label prevLowLabel  = na

// Current High Label
if showCurrentHigh and not na(currHigh)
    if showCurrHighLabel
        if na(currHighLabel)
            currHighLabel := label.new(rightX, currHigh, currHighLabelText, style=label.style_none, textcolor=currHighLabelColor, size=f_size(currHighLabelSize))
        else
            label.set_xy(currHighLabel, rightX, currHigh)
            label.set_text(currHighLabel, currHighLabelText)
            label.set_textcolor(currHighLabel, currHighLabelColor)
            label.set_size(currHighLabel, f_size(currHighLabelSize))
    else
        label.delete(currHighLabel)
        currHighLabel := na

// Current Low Label
if showCurrentLow and not na(currLow)
    if showCurrLowLabel
        if na(currLowLabel)
            currLowLabel := label.new(rightX, currLow, currLowLabelText, style=label.style_none, textcolor=currLowLabelColor, size=f_size(currLowLabelSize))
        else
            label.set_xy(currLowLabel, rightX, currLow)
            label.set_text(currLowLabel, currLowLabelText)
            label.set_textcolor(currLowLabel, currLowLabelColor)
            label.set_size(currLowLabel, f_size(currLowLabelSize))
    else
        label.delete(currLowLabel)
        currLowLabel := na

// Previous High Label
if showPrevHigh and not na(prevHigh)
    if showPrevHighLabel
        if isNewDay
            label.delete(prevHighLabel)
            prevHighLabel := label.new(rightX, prevHigh, prevHighLabelText, style=label.style_none, textcolor=prevHighLabelColor, size=f_size(prevHighLabelSize))
        else
            label.set_xy(prevHighLabel, rightX, prevHigh)
            label.set_text(prevHighLabel, prevHighLabelText)
            label.set_textcolor(prevHighLabel, prevHighLabelColor)
            label.set_size(prevHighLabel, f_size(prevHighLabelSize))
    else
        label.delete(prevHighLabel)
        prevHighLabel := na

// Previous Low Label
if showPrevLow and not na(prevLow)
    if showPrevLowLabel
        if isNewDay
            label.delete(prevLowLabel)
            prevLowLabel := label.new(rightX, prevLow, prevLowLabelText, style=label.style_none, textcolor=prevLowLabelColor, size=f_size(prevLowLabelSize))
        else
            label.set_xy(prevLowLabel, rightX, prevLow)
            label.set_text(prevLowLabel, prevLowLabelText)
            label.set_textcolor(prevLowLabel, prevLowLabelColor)
            label.set_size(prevLowLabel, f_size(prevLowLabelSize))
    else
        label.delete(prevLowLabel)
        prevLowLabel := na
